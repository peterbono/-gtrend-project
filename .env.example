# Nom EXACT du groupe WhatsApp a ecouter (tel qu'il apparait dans l'app)
GROUP_NAME=PDC Dance Socials

# Port de la web app
PORT=3000

# --- Liaison SANS QR (pratique sur mobile) ---
# Ton numero WhatsApp avec indicatif pays, chiffres uniquement (ex Mexique : 5219991234567).
# Si renseigne, l'app affiche un CODE a taper dans WhatsApp au lieu d'un QR a scanner.
# Laisse vide pour utiliser le QR classique.
LINK_PHONE=

# --- Vision (OPTIONNEL, GRATUIT) ---
# Si renseigne, les messages qui ne contiennent QU'une image (flyer sans texte)
# seront lus par Google Gemini pour en extraire les evenements.
# Cree une cle sur https://aistudio.google.com/app/apikey (free tier 15 RPM / 1500 RPD).
GEMINI_API_KEY=
VISION_MODEL=gemini-2.0-flash

# --- Stockage partage Upstash Redis (pour le lien Vercel LIVE) ---
# Cree une base gratuite sur upstash.com (ou via Vercel Marketplace > Redis).
# Mets les MEMES valeurs cote listener (ici) ET cote Vercel.
# Laisse vide pour rester 100% local (fichier data/events.json).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
