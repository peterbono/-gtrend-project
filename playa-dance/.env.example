# Nom EXACT du groupe WhatsApp a ecouter (tel qu'il apparait dans l'app)
GROUP_NAME=PDC Dance Socials

# Port de la web app
PORT=3000

# --- Vision (OPTIONNEL) ---
# Si renseigne, les messages qui ne contiennent QU'une image (flyer sans texte)
# seront lus par Claude vision pour en extraire les evenements.
# Laisse vide pour desactiver (parsing texte uniquement, gratuit).
ANTHROPIC_API_KEY=
VISION_MODEL=claude-opus-4-8

# --- Stockage partage Upstash Redis (pour le lien Vercel LIVE) ---
# Cree une base gratuite sur upstash.com (ou via Vercel Marketplace > Redis).
# Mets les MEMES valeurs cote listener (ici) ET cote Vercel.
# Laisse vide pour rester 100% local (fichier data/events.json).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
