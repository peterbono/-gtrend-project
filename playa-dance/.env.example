# Nom EXACT du groupe WhatsApp a ecouter (tel qu'il apparait dans l'app)
GROUP_NAME=PDC Dance Socials

# Port de la web app
PORT=3000

# --- Vision (OPTIONNEL) ---
# Si renseigne, les messages qui ne contiennent QU'une image (flyer sans texte)
# seront lus par Claude vision pour en extraire les evenements.
# Laisse vide pour desactiver (parsing texte uniquement, gratuit).
ANTHROPIC_API_KEY=
VISION_MODEL=claude-opus-4-8
